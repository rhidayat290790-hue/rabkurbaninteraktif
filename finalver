    <!-- LOGIKA JAVASCRIPT APLIKASI -->
    <script>
        // Data Default Template untuk inisialisasi pertama kali
        const defaultPemasukan = [
            { uraian: "Iuran Hewan Sapi Kelompok A", volume: 1, satuan: "Paket", harga: 21000000 },
            { uraian: "Iuran Hewan Sapi Kelompok B", volume: 1, satuan: "Paket", harga: 21000000 },
            { uraian: "Iuran Hewan Kambing Individu (Pak Ahmad)", volume: 1, satuan: "Ekor", harga: 3200000 },
            { uraian: "Infaq Operasional / Kas Sekolah", volume: 1, satuan: "Paket", harga: 1500000 }
        ];

        const defaultPengeluaran = [
            { uraian: "Pembelian Hewan Sapi Kelompok A", kategori: "hewan kurban", volume: 1, satuan: "Ekor", harga: 19500000 },
            { uraian: "Pembelian Hewan Sapi Kelompok B", kategori: "hewan kurban", volume: 1, satuan: "Ekor", harga: 19500000 },
            { uraian: "Pembelian Hewan Kambing", kategori: "hewan kurban", volume: 1, satuan: "Ekor", harga: 3000000 },
            { uraian: "Sewa Terop dan Panggung Utama", kategori: "perlengkapan", volume: 1, satuan: "Set", harga: 800000 },
            { uraian: "Konsumsi Panitia dan Warga (Hari H)", kategori: "konsumsi", volume: 50, satuan: "Kotak", harga: 15000 },
            { uraian: "Cetak Banner & Dokumentasi Kegiatan", kategori: "humas dan dokumentasi", volume: 1, satuan: "Paket", harga: 350000 }
        ];

        // State global aplikasi
        let dataPemasukan = [];
        let dataPengeluaran = [];
        let activeTab = 'pemasukan';

        // Inisialisasi Aplikasi Saat Memuat Halaman
        window.addEventListener('load', () => {
            // Coba ambil dari localStorage, jika tidak ada pakai default template
            const localPemasukan = localStorage.getItem('rab_pemasukan');
            const localPengeluaran = localStorage.getItem('rab_pengeluaran');

            if (localPemasukan) {
                dataPemasukan = JSON.parse(localPemasukan);
            } else {
                dataPemasukan = [...defaultPemasukan];
            }

            if (localPengeluaran) {
                dataPengeluaran = JSON.parse(localPengeluaran);
            } else {
                dataPengeluaran = [...defaultPengeluaran];
            }

            renderTables();
            updateCalculations();
            
            // Set default view tab
            switchTab('pemasukan');
        });

        // Alih Halaman / Tab (Hanya berlaku di layar monitor, saat print semua akan tercetak)
        function switchTab(tab) {
            activeTab = tab;
            const tabPem = document.getElementById('tab-pemasukan');
            const tabPeng = document.getElementById('tab-pengeluaran');
            const secPem = document.getElementById('section-pemasukan');
            const secPeng = document.getElementById('section-pengeluaran');

            if (tab === 'pemasukan') {
                tabPem.className = "border-b-2 border-emerald-600 text-emerald-700 px-4 py-2.5 font-bold text-sm flex items-center gap-2 transition duration-150";
                tabPeng.className = "border-b-2 border-transparent text-slate-500 hover:text-slate-700 hover:border-slate-300 px-4 py-2.5 font-bold text-sm flex items-center gap-2 transition duration-150";
                secPem.style.display = "block";
                secPeng.classList.add('hidden');
                secPeng.classList.remove('md:block');
            } else {
                tabPeng.className = "border-b-2 border-rose-600 text-rose-700 px-4 py-2.5 font-bold text-sm flex items-center gap-2 transition duration-150";
                tabPem.className = "border-b-2 border-transparent text-slate-500 hover:text-slate-700 hover:border-slate-300 px-4 py-2.5 font-bold text-sm flex items-center gap-2 transition duration-150";
                secPeng.classList.remove('hidden');
                secPeng.classList.add('md:block');
                secPem.style.display = "none";
            }
        }

        // Render Data ke Dalam Tabel HTML
        function renderTables() {
            // Render Pemasukan
            const pemBody = document.getElementById('table-pemasukan-body');
            pemBody.innerHTML = '';
            
            dataPemasukan.forEach((item, index) => {
                const tr = document.createElement('tr');
                tr.className = "hover:bg-slate-50/50 transition duration-150";
                tr.innerHTML = `
                    <td class="py-3 px-4 text-sm text-center font-medium text-slate-500">${index + 1}</td>
                    <td class="py-3 px-4 text-sm font-semibold">
                        <input type="text" value="${item.uraian}" oninput="updateItem('pemasukan', ${index}, 'uraian', this.value)" placeholder="Nama Sumber Dana..." class="w-full bg-transparent focus:bg-white focus:outline-none focus:ring-2 focus:ring-emerald-500 rounded px-2 py-1 text-slate-800 font-semibold border border-transparent hover:border-slate-200">
                    </td>
                    <td class="py-3 px-4 text-sm text-center">
                        <input type="number" value="${item.volume}" oninput="updateItem('pemasukan', ${index}, 'volume', this.value)" class="w-full text-center bg-transparent focus:bg-white focus:outline-none focus:ring-2 focus:ring-emerald-500 rounded px-2 py-1 border border-transparent hover:border-slate-200">
                    </td>
                    <td class="py-3 px-4 text-sm text-center">
                        <input type="text" value="${item.satuan}" oninput="updateItem('pemasukan', ${index}, 'satuan', this.value)" placeholder="Ekor/Paket..." class="w-full text-center bg-transparent focus:bg-white focus:outline-none focus:ring-2 focus:ring-emerald-500 rounded px-2 py-1 border border-transparent hover:border-slate-200">
                    </td>
                    <td class="py-3 px-4 text-sm text-right">
                        <input type="number" value="${item.harga}" oninput="updateItem('pemasukan', ${index}, 'harga', this.value)" class="w-full text-right bg-transparent focus:bg-white focus:outline-none focus:ring-2 focus:ring-emerald-500 rounded px-2 py-1 font-mono border border-transparent hover:border-slate-200">
                    </td>
                    <td class="py-3 px-4 text-sm text-right font-semibold font-mono text-slate-700">
                        ${formatRupiah(item.volume * item.harga)}
                    </td>
                    <td class="py-3 px-4 text-center no-print">
                        <button onclick="deleteRow('pemasukan', ${index})" class="text-rose-600 hover:text-rose-800 p-1 rounded-full hover:bg-rose-50 transition duration-150" title="Hapus Baris">
                            <i class="fa-solid fa-trash"></i>
                        </button>
                    </td>
                `;
                pemBody.appendChild(tr);
            });

            // Render Pengeluaran
            const pengBody = document.getElementById('table-pengeluaran-body');
            pengBody.innerHTML = '';
            
            dataPengeluaran.forEach((item, index) => {
                const tr = document.createElement('tr');
                tr.className = "hover:bg-slate-50/50 transition duration-150";
                
                // Kategori select options
                const categories = [
                    { val: 'hewan kurban', label: 'Hewan Kurban' },
                    { val: 'operasional', label: 'Operasional' },
                    { val: 'perlengkapan', label: 'Perlengkapan' },
                    { val: 'konsumsi', label: 'Konsumsi' },
                    { val: 'humas dan dokumentasi', label: 'Humas & Dokumentasi' },
                    { val: 'kas/lainnya', label: 'Kas/Lainnya' }
                ];

                let selectOptions = '';
                categories.forEach(cat => {
                    selectOptions += `<option value="${cat.val}" ${item.kategori === cat.val ? 'selected' : ''}>${cat.label}</option>`;
                });

                tr.innerHTML = `
                    <td class="py-3 px-4 text-sm text-center font-medium text-slate-500">${index + 1}</td>
                    <td class="py-3 px-4 text-sm font-semibold">
                        <input type="text" value="${item.uraian}" oninput="updateItem('pengeluaran', ${index}, 'uraian', this.value)" placeholder="Nama Barang/Jasa..." class="w-full bg-transparent focus:bg-white focus:outline-none focus:ring-2 focus:ring-rose-500 rounded px-2 py-1 text-slate-800 font-semibold border border-transparent hover:border-slate-200">
                    </td>
                    <td class="py-3 px-4 text-sm">
                        <select onchange="updateItem('pengeluaran', ${index}, 'kategori', this.value)" class="w-full bg-transparent focus:bg-white focus:outline-none focus:ring-2 focus:ring-rose-500 rounded px-2 py-1 text-xs font-semibold uppercase text-slate-600 border border-transparent hover:border-slate-200">
                            ${selectOptions}
                        </select>
                    </td>
                    <td class="py-3 px-4 text-sm text-center">
                        <input type="number" value="${item.volume}" oninput="updateItem('pengeluaran', ${index}, 'volume', this.value)" class="w-full text-center bg-transparent focus:bg-white focus:outline-none focus:ring-2 focus:ring-rose-500 rounded px-2 py-1 border border-transparent hover:border-slate-200">
                    </td>
                    <td class="py-3 px-4 text-sm text-center">
                        <input type="text" value="${item.satuan}" oninput="updateItem('pengeluaran', ${index}, 'satuan', this.value)" placeholder="Set/Kotak..." class="w-full text-center bg-transparent focus:bg-white focus:outline-none focus:ring-2 focus:ring-rose-500 rounded px-2 py-1 border border-transparent hover:border-slate-200">
                    </td>
                    <td class="py-3 px-4 text-sm text-right">
                        <input type="number" value="${item.harga}" oninput="updateItem('pengeluaran', ${index}, 'harga', this.value)" class="w-full text-right bg-transparent focus:bg-white focus:outline-none focus:ring-2 focus:ring-rose-500 rounded px-2 py-1 font-mono border border-transparent hover:border-slate-200">
                    </td>
                    <td class="py-3 px-4 text-sm text-right font-semibold font-mono text-slate-700">
                        ${formatRupiah(item.volume * item.harga)}
                    </td>
                    <td class="py-3 px-4 text-center no-print">
                        <button onclick="deleteRow('pengeluaran', ${index})" class="text-rose-600 hover:text-rose-800 p-1 rounded-full hover:bg-rose-50 transition duration-150" title="Hapus Baris">
                            <i class="fa-solid fa-trash"></i>
                        </button>
                    </td>
                `;
                pengBody.appendChild(tr);
            });
        }

        // Update Item di Memory State
        function updateItem(type, index, field, value) {
            if (type === 'pemasukan') {
                if (field === 'volume' || field === 'harga') {
                    dataPemasukan[index][field] = parseFloat(value) || 0;
                } else {
                    dataPemasukan[index][field] = value;
                }
            } else {
                if (field === 'volume' || field === 'harga') {
                    dataPengeluaran[index][field] = parseFloat(value) || 0;
                } else {
                    dataPengeluaran[index][field] = value;
                }
            }
            
            // Render sub-total baris ini tanpa re-render semua agar performa input lancar
            updateCalculations();
        }

        // Tambah Baris Kosong Baru
        function addRow(type) {
            if (type === 'pemasukan') {
                dataPemasukan.push({ uraian: '', volume: 1, satuan: 'Pcs', harga: 0 });
            } else {
                dataPengeluaran.push({ uraian: '', kategori: 'operasional', volume: 1, satuan: 'Pcs', harga: 0 });
            }
            renderTables();
            updateCalculations();
            showToast("Baris rincian baru berhasil ditambahkan!");
        }

        // Hapus Baris Rincian
        function deleteRow(type, index) {
            if (type === 'pemasukan') {
                dataPemasukan.splice(index, 1);
            } else {
                dataPengeluaran.splice(index, 1);
            }
            renderTables();
            updateCalculations();
            showToast("Baris rincian berhasil dihapus.", "warning");
        }

        // Hitung Ulang Total Pemasukan, Pengeluaran, & Surplus
        function updateCalculations() {
            let totalA = 0;
            let totalB = 0;

            // Kalkulasi Pemasukan
            dataPemasukan.forEach(item => {
                totalA += (item.volume * item.harga);
            });

            // Kalkulasi Pengeluaran
            dataPengeluaran.forEach(item => {
                totalB += (item.volume * item.harga);
            });

            const surplus = totalA - totalB;

            // Render ke tabel footer
            document.getElementById('total-pemasukan').innerText = formatRupiah(totalA);
            document.getElementById('total-pengeluaran').innerText = formatRupiah(totalB);

            // Render ke Dashboard Atas
            document.getElementById('dash-pemasukan').innerText = formatRupiah(totalA);
            document.getElementById('dash-pengeluaran').innerText = formatRupiah(totalB);
            document.getElementById('dash-surplus').innerText = formatRupiah(surplus);

            // Perbarui warna status surplus (Jika minus berwarna merah, jika surplus berwarna biru/hijau)
            const surplusContainer = document.getElementById('dash-surplus-container');
            const surplusIcon = document.getElementById('dash-surplus-icon');
            
            if (surplus < 0) {
                surplusContainer.className = "bg-gradient-to-br from-red-50 to-red-100 border border-red-200 rounded-xl p-5 shadow-sm flex items-center justify-between";
                surplusIcon.className = "bg-red-600 text-white p-3 rounded-lg text-xl no-print";
            } else {
                surplusContainer.className = "bg-gradient-to-br from-cyan-50 to-cyan-100 border border-cyan-200 rounded-xl p-5 shadow-sm flex items-center justify-between";
                surplusIcon.className = "bg-cyan-600 text-white p-3 rounded-lg text-xl no-print";
            }

            // Update sub-total visual secara instan pada input terfokus
            const pemRows = document.querySelectorAll('#table-pemasukan-body tr');
            dataPemasukan.forEach((item, index) => {
                if(pemRows[index]) {
                    pemRows[index].cells[5].innerText = formatRupiah(item.volume * item.harga);
                }
            });

            const pengRows = document.querySelectorAll('#table-pengeluaran-body tr');
            dataPengeluaran.forEach((item, index) => {
                if(pengRows[index]) {
                    pengRows[index].cells[6].innerText = formatRupiah(item.volume * item.harga);
                }
            });
        }

        // Formatter Mata Uang Rupiah
        function formatRupiah(angka) {
            return "Rp " + new Intl.NumberFormat('id-ID', { minimumFractionDigits: 0 }).format(angka);
        }

        // Simpan Data Saat Ini ke Local Storage
        function saveData() {
            localStorage.setItem('rab_pemasukan', JSON.stringify(dataPemasukan));
            localStorage.setItem('rab_pengeluaran', JSON.stringify(dataPengeluaran));
            showToast("Semua data berhasil disimpan ke penyimpanan lokal browser Anda!", "success");
        }

        // Reset Semua Data ke Kosong / Template Default
        function confirmReset() {
            if (confirm("Apakah Anda yakin ingin menyetel ulang (reset) data? Tindakan ini akan mengosongkan perubahan Anda.")) {
                localStorage.removeItem('rab_pemasukan');
                localStorage.removeItem('rab_pengeluaran');
                dataPemasukan = [...defaultPemasukan];
                dataPengeluaran = [...defaultPengeluaran];
                renderTables();
                updateCalculations();
                showToast("Data e-RAB telah di-reset ke template awal.", "warning");
            }
        }

        // Ekspor ke Spreadsheet Format XLS (XLSX format)
        function exportToXLS() {
            try {
                // Buat workbook baru
                const wb = XLSX.utils.book_new();

                // Format data pemasukan untuk excel
                const extPemasukan = dataPemasukan.map((item, index) => ({
                    "No": index + 1,
                    "Uraian Deskripsi Sumber Dana": item.uraian,
                    "Volume": item.volume,
                    "Satuan": item.satuan,
                    "Harga Satuan (Rp)": item.harga,
                    "Sub Total (Rp)": item.volume * item.harga
                }));
                const wsPem = XLSX.utils.json_to_sheet(extPemasukan);
                XLSX.utils.book_append_sheet(wb, wsPem, "Pemasukan");

                // Format data pengeluaran untuk excel
                const extPengeluaran = dataPengeluaran.map((item, index) => ({
                    "No": index + 1,
                    "Divisi / Deskripsi Belanja": item.uraian,
                    "Kategori Divisi": item.kategori.toUpperCase(),
                    "Volume": item.volume,
                    "Satuan": item.satuan,
                    "Harga Satuan (Rp)": item.harga,
                    "Sub Total (Rp)": item.volume * item.harga
                }));
                const wsPeng = XLSX.utils.json_to_sheet(extPengeluaran);
                XLSX.utils.book_append_sheet(wb, wsPeng, "Pengeluaran");

                // Generate File download
                XLSX.writeFile(wb, "RAB_Kurban_2026_SDIT_Insan_Cendekia.xlsx");
                showToast("File e-RAB Excel (.xlsx) berhasil di-ekspor!", "success");
            } catch (err) {
                showToast("Gagal melakukan ekspor data.", "error");
                console.error(err);
            }
        }

        // Impor dari file Excel (.xls / .xlsx)
        function importFromXLS(event) {
            const file = event.target.files[0];
            if (!file) return;

            const reader = new FileReader();
            reader.onload = function(e) {
                try {
                    const data = new Uint8Array(e.target.result);
                    const workbook = XLSX.read(data, { type: 'array' });

                    // Baca sheet pertama (Pemasukan)
                    if (workbook.SheetNames.includes("Pemasukan")) {
                        const wsPem = workbook.Sheets["Pemasukan"];
                        const jsonPem = XLSX.utils.sheet_to_json(wsPem);
                        dataPemasukan = jsonPem.map(row => ({
                            uraian: row["Uraian Deskripsi Sumber Dana"] || "",
                            volume: parseFloat(row["Volume"]) || 1,
                            satuan: row["Satuan"] || "Pcs",
                            harga: parseFloat(row["Harga Satuan (Rp)"]) || 0
                        }));
                    }

                    // Baca sheet kedua (Pengeluaran)
                    if (workbook.SheetNames.includes("Pengeluaran")) {
                        const wsPeng = workbook.Sheets["Pengeluaran"];
                        const jsonPeng = XLSX.utils.sheet_to_json(wsPeng);
                        dataPengeluaran = jsonPeng.map(row => ({
                            uraian: row["Divisi / Deskripsi Belanja"] || "",
                            kategori: (row["Kategori Divisi"] || "operasional").toLowerCase(),
                            volume: parseFloat(row["Volume"]) || 1,
                            satuan: row["Satuan"] || "Pcs",
                            harga: parseFloat(row["Harga Satuan (Rp)"]) || 0
                        }));
                    }

                    renderTables();
                    updateCalculations();
                    saveData();
                    showToast("Data dari Excel berhasil di-impor!", "success");
                } catch (err) {
                    showToast("Format Excel tidak sesuai. Gagal impor data.", "error");
                    console.error(err);
                }
            };
            reader.readAsArrayBuffer(file);
            // Reset input file value agar bisa mengimpor file yang sama lagi jika perlu
            event.target.value = '';
        }

        // Tampilkan Toast Notifikasi Kecil
        function showToast(message, status = "success") {
            const toast = document.getElementById('toast');
            const icon = document.getElementById('toast-icon');
            const msg = document.getElementById('toast-message');

            msg.innerText = message;
            
            // Set icon and background based on status
            if (status === "success") {
                toast.className = "fixed bottom-5 right-5 bg-emerald-900 text-white text-sm py-2 px-4 rounded-lg shadow-lg opacity-100 z-50 flex items-center gap-2 transition-all duration-300";
                icon.innerHTML = '<i class="fa-solid fa-circle-check text-emerald-400"></i>';
            } else if (status === "warning") {
                toast.className = "fixed bottom-5 right-5 bg-amber-950 text-white text-sm py-2 px-4 rounded-lg shadow-lg opacity-100 z-50 flex items-center gap-2 transition-all duration-300";
                icon.innerHTML = '<i class="fa-solid fa-triangle-exclamation text-amber-400"></i>';
            } else {
                toast.className = "fixed bottom-5 right-5 bg-rose-950 text-white text-sm py-2 px-4 rounded-lg shadow-lg opacity-100 z-50 flex items-center gap-2 transition-all duration-300";
                icon.innerHTML = '<i class="fa-solid fa-circle-xmark text-rose-400"></i>';
            }

            // Hilangkan toast setelah 3.5 detik
            setTimeout(() => {
                toast.classList.add('opacity-0');
                toast.classList.add('pointer-events-none');
            }, 3500);
        }
    </script>
</body>
